{
    "compilerOptions": {
        "target": "esnext",
        "lib": [
            "esnext",
            "dom"
        ],
        "rootDir": ".",
        "module": "commonjs",
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "useDefineForClassFields": false,
        "strictNullChecks": false,
        "paths": {
            "*": [
                "./*"
            ],
        },
        "skipLibCheck": true
    },
    "include": [
        "**/*.ts"
    ],
    "exclude": [
        "node_modules/**/.*",
        "playwright-report",
        "test-results",
        "archivedCypressCode"
    ],
}